generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MERCHANT_ADMIN
}

enum MerchantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum CheckoutSessionStatus {
  PENDING
  COMPLETED
  CANCELLED
  EXPIRED
}

enum TransactionStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  VOIDED
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

model User {
  id           String    @id @default(cuid())
  fullName     String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(MERCHANT_ADMIN)
  merchant     Merchant? @relation("MerchantOwner")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([role])
}

model Merchant {
  id               String            @id @default(cuid())
  ownerId          String            @unique
  owner            User              @relation("MerchantOwner", fields: [ownerId], references: [id])
  businessName     String
  businessType     String
  country          String
  currency         String
  status           MerchantStatus    @default(PENDING)
  customers        Customer[]
  checkoutSessions CheckoutSession[]
  transactions     Transaction[]
  ledgerEntries    LedgerEntry[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([ownerId])
}

model Customer {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  email      String?
  name       String?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([merchantId, externalId])
  @@index([merchantId])
}

model CheckoutSession {
  id            String                @id @default(cuid())
  merchantId    String
  merchant      Merchant              @relation(fields: [merchantId], references: [id])
  amount        Decimal               @db.Decimal(19, 4)
  currency      String
  customerEmail String
  customerName  String
  description   String?
  successUrl    String
  cancelUrl     String
  status        CheckoutSessionStatus @default(PENDING)
  expiresAt     DateTime
  transactions  Transaction[]
  metadata      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([merchantId, status])
  @@index([expiresAt])
}

model Transaction {
  id                String            @id @default(cuid())
  merchantId        String
  merchant          Merchant          @relation(fields: [merchantId], references: [id])
  checkoutSessionId String?
  checkoutSession   CheckoutSession?  @relation(fields: [checkoutSessionId], references: [id])
  amount            Decimal           @db.Decimal(19, 4)
  currency          String
  status            TransactionStatus @default(CREATED)
  providerReference String?
  ledgerEntries     LedgerEntry[]
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([merchantId, status])
  @@index([checkoutSessionId])
}

model LedgerEntry {
  id            String          @id @default(cuid())
  merchantId    String
  merchant      Merchant        @relation(fields: [merchantId], references: [id])
  transactionId String?
  transaction   Transaction?    @relation(fields: [transactionId], references: [id])
  type          LedgerEntryType
  amount        Decimal         @db.Decimal(19, 4)
  currency      String
  description   String?
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([merchantId, createdAt])
  @@index([transactionId])
}
